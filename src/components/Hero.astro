---
// Hero com a regressão interativa (canvas #reg controlado por portfolio.ts)
import L from './L.astro';
---

<section class="hero">
  <div class="wrap hero-grid">
    <div class="identity">
      <p class="cell-label">In [00]:</p>
      <L as="p" class="eyebrow" en="hi, I'm" pt="olá, eu sou" />
      <h1 class="hero-name">Henrique<br />Targino</h1>
      <svg class="underline" viewBox="0 0 380 22" preserveAspectRatio="none" aria-hidden="true">
        <path pathLength="1" d="M4,14 C 70,6 110,18 170,10 C 230,3 270,17 330,9 C 350,7 366,11 376,10" />
      </svg>
      <L as="p" class="role" en="AI Engineer & Data Scientist" pt="AI Engineer e Cientista de Dados" />
      <L
        as="p"
        class="statement"
        html
        en="Building machines that see, learn and talk. I still find that <mark>surreal</mark>."
        pt="Construindo máquinas que enxergam, aprendem e conversam. Ainda acho isso <mark>surreal</mark>."
      />
      <L
        as="p"
        class="play-hint"
        en="→ drag the chart points and watch the line refit"
        pt="→ arraste os pontos do gráfico e veja a reta se reajustar"
      />
    </div>

    <figure class="figure data-zone">
      <div class="fig-top">
        <span class="num">fig.01</span>
        <L en="least squares regression" pt="regressão de mínimos quadrados" />
      </div>
      <canvas id="reg"></canvas>
      <figcaption class="figcap">
        <span class="eq" id="eq">ŷ = …</span>
        <span class="r2" id="r2">R² = …</span>
        <L class="muted" en="n = 9 · drag the points" pt="n = 9 · arraste os pontos" />
      </figcaption>
    </figure>
  </div>
</section>
