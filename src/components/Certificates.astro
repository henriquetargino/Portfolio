---
import { certificates } from '../data/certificates';
import L from './L.astro';
const base = import.meta.env.BASE_URL;
const withImage = certificates.filter((c) => c.image);
// carrossel começa na Asimov (Harvard cai no centro); o resto segue a ordem da grade
const carousel = [
  ...withImage.filter((c) => c.institution === 'Asimov Academy'),
  ...withImage.filter((c) => c.institution !== 'Asimov Academy'),
];
const loop = [...carousel, ...carousel];
---

<section class="certs" id="certificados">
  <div class="wrap">
    <p class="cell-label out">Out [07]:</p>
    <L as="h3" class="exp-sub" en="// certificates" pt="// certificados" />
  </div>
  <div class="cert-carousel" id="cert-carousel">
    <div class="cert-track">
      {loop.map((c) => (
        <a class="cert-slide" href={`${base}${c.doc || c.image}`} target="_blank" rel="noopener" aria-label={c.titleEn ?? c.title}>
          <img src={`${base}${c.image}`} alt={c.titleEn ?? c.title} loading="lazy" />
        </a>
      ))}
    </div>
  </div>
  <div class="wrap" style="margin-top:1.6rem;">
    <a class="band-link" href={`${base}certificados`}><L en="see all certificates →" pt="ver todos os certificados →" /></a>
  </div>
</section>
