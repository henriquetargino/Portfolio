---
const base = import.meta.env.BASE_URL;

const certs = [
  { img: 'images/certificado_harvard.png', title: 'CS50 — Harvard' },
  { img: 'images/certificado_tripleten.png', title: 'Bootcamp em Ciência de Dados — TripleTen' },
  { img: 'images/certificado_asimov_visao.png', title: 'Visão Computacional com OpenCV — Asimov' },
];
// duplicado para o loop infinito perfeito do carrossel
const loop = [...certs, ...certs];
---

<section class="certs" id="certificados">
  <div class="wrap">
    <p class="cell-label out">Out [07]:</p>
    <h3 class="exp-sub">// certificados</h3>
  </div>
  <div class="cert-carousel" id="cert-carousel">
    <div class="cert-track">
      {loop.map((c) => (
        <a class="cert-slide" href={`${base}${c.img}`} target="_blank" rel="noopener" aria-label={c.title}>
          <img src={`${base}${c.img}`} alt={c.title} loading="lazy" />
        </a>
      ))}
    </div>
  </div>
</section>
