---
import L from './L.astro';
const base = import.meta.env.BASE_URL;

interface I18n { en: string; pt: string; }
interface BodyCol { h4: I18n; text: I18n; }
interface Props {
  cell: string;
  kind: I18n;
  title: I18n;
  lead: I18n;
  img: string;
  imgAlt: string;
  figPhotoCap: I18n;
  rep: 'hand' | 'nn';
  figRepCap: I18n;
  body: BodyCol[];
  tags: string[];
  metricValue: string;
  metricLabel: I18n;
  href: string;
  slug: string;
  id?: string;
  alt?: boolean;
}

const {
  cell, kind, title, lead, img, imgAlt, figPhotoCap, rep, figRepCap,
  body, tags, metricValue, metricLabel, href, slug, id, alt = false,
} = Astro.props;
---

<section class={alt ? 'feature alt' : 'feature'} id={id}>
  <div class="wrap">
    <p class="cell-label">{cell}</p>
    <L as="span" class="kind" en={kind.en} pt={kind.pt} />
    <L as="h2" en={title.en} pt={title.pt} />
    <L as="p" class="lead" html en={lead.en} pt={lead.pt} />

    <div class="fig-pair">
      <figure class="fig-cell">
        <div class="fig-frame">
          <a class="fig-link" href={href} aria-label={`abrir ${title.en}`}>
            {img.endsWith('.mp4') ? (
              <video src={`${base}${img}`} autoplay loop muted playsinline data-autopause aria-label={imgAlt} transition:name={`cover-${slug}`}></video>
            ) : (
              <img src={`${base}${img}`} alt={imgAlt} transition:name={`cover-${slug}`} />
            )}
          </a>
        </div>
        <figcaption><L html en={figPhotoCap.en} pt={figPhotoCap.pt} /></figcaption>
      </figure>
      <svg class="fig-arrow" viewBox="0 0 56 38" aria-hidden="true">
        <path d="M3,19 C 22,9 36,29 48,19" />
        <path d="M48,19 l-9,-4 M48,19 l-8,6" />
      </svg>
      <figure class="fig-cell">
        <div class="fig-frame rep"><canvas id={rep}></canvas></div>
        <figcaption><L html en={figRepCap.en} pt={figRepCap.pt} /></figcaption>
      </figure>
    </div>

    <div class="feature-body">
      {body.map((col) => (
        <div>
          <h4><L en={col.h4.en} pt={col.h4.pt} /></h4>
          <L as="p" html en={col.text.en} pt={col.text.pt} />
        </div>
      ))}
    </div>

    <div class="feature-foot">
      <div class="tags">{tags.map((t) => <span>{t}</span>)}</div>
      <div class="metric"><b>{metricValue}</b><span><L en={metricLabel.en} pt={metricLabel.pt} /></span></div>
      <a class="band-link" href={href}><L en="open full case study →" pt="abrir ficha completa →" /></a>
    </div>
  </div>
</section>
