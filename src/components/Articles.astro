---
import { articles } from '../data/articles';
import L from '../components/L.astro';
const base = import.meta.env.BASE_URL;
const article = articles[0];
---

<section class="section-block" id="artigos">
  <div class="wrap">
    <p class="cell-label out">Out [06]:</p>
    <L as="h3" class="exp-sub" en="// articles" pt="// artigos" />
    <a class="article-card" href={article.href} target="_blank" rel="noopener">
      <div class="article-cover"><img src={`${base}${article.cover}`} alt="AI position heatmap: start vs end of training" /></div>
      <div class="article-body">
        <L as="span" class="pub" en={article.pubEn ?? article.pub} pt={article.pub} />
        <h3>{article.title}</h3>
        <L as="p" class="article-excerpt" html en={article.excerptEn ?? article.excerpt} pt={article.excerpt} />
        <L as="span" class="article-go" en="read on Medium →" pt="ler no Medium →" />
      </div>
    </a>
  </div>
</section>
