---
// Move 4 — terminal escondido (easter egg). Abre com "/" em qualquer página.
// O comportamento (abrir, executar comandos) está em scripts/portfolio.ts.
---

<div id="term" class="term" role="dialog" aria-label="terminal">
  <div class="term-head">
    <span>portfolio.ipynb — shell</span>
    <button id="term-close" class="term-x" type="button" aria-label="fechar (esc)">esc</button>
  </div>
  <div id="term-out" class="term-out"></div>
  <div class="term-line">
    <span class="term-prompt">&gt;&gt;&gt;</span>
    <input id="term-in" class="term-in" type="text" autocomplete="off" autocapitalize="off" autocorrect="off" spellcheck="false" aria-label="comando" />
  </div>
</div>
