---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Cursor from '../components/Cursor.astro';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Henrique Targino · Cientista de Dados',
  description = 'Portfólio de Henrique Targino — Cientista de Dados apaixonado por redes neurais e visão computacional.',
  lang = 'pt-BR',
} = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="paper">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=JetBrains+Mono:wght@400;500;700&family=Shantell+Sans:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&display=swap" rel="stylesheet" />
</head>

<body>
  <TopBar />
  <slot />
  <Cursor />
  <script>import '../scripts/portfolio.ts';</script>
</body>

</html>
