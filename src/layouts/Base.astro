---
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Cursor from '../components/Cursor.astro';
import Terminal from '../components/Terminal.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  ogImage?: string; // path relativo dentro de /public (ex: 'og.png' ou 'images/aif_intro.png')
}

const {
  title = 'Henrique Targino · AI Engineer & Data Scientist',
  description = 'Building machines that see, learn and talk. Portfolio of Henrique Targino: neural networks, computer vision and AI agents.',
  ogImage = 'og.png',
} = Astro.props;

// URLs absolutas (necessárias pra og:image, og:url, canonical)
const SITE = Astro.site?.toString().replace(/\/$/, '') || 'https://henriquetargino.github.io';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const ogImageUrl = `${SITE}${BASE}/${ogImage.replace(/^\//, '')}`;
const canonicalUrl = `${SITE}${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en" data-lang="en" data-theme="paper">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="author" content="Henrique Targino" />
  <meta name="theme-color" content="#F4F0E7" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="48x48" />
  <link rel="icon" type="image/png" sizes="96x96" href={`${import.meta.env.BASE_URL}favicon-96.png`} />
  <link rel="icon" type="image/png" sizes="48x48" href={`${import.meta.env.BASE_URL}favicon-48.png`} />
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  <link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
  <title>{title}</title>

  {/* Open Graph (LinkedIn, Facebook, WhatsApp) */}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Henrique Targino · Portfolio" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:locale:alternate" content="pt_BR" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Henrique Targino · AI Engineer & Cientista de Dados" />

  {/* Twitter / X */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content="Henrique Targino · AI Engineer & Cientista de Dados" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=JetBrains+Mono:wght@400;500;700&family=Shantell+Sans:wght@400;500;600&display=swap"
    rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600,700&f[]=zodiak@700,900&display=swap" rel="stylesheet" />
  <script is:inline>
    // aplica o idioma salvo antes da pintura (default EN, evita flash de troca)
    try {
      var lg = localStorage.getItem('lang') || 'en';
      document.documentElement.setAttribute('data-lang', lg);
      document.documentElement.setAttribute('lang', lg === 'pt' ? 'pt-BR' : 'en');
    } catch (e) { }
    // refresh começa no topo (hero): impede o navegador de restaurar a rolagem antiga
    try { history.scrollRestoration = 'manual'; } catch (e) { }
  </script>
  <script is:inline define:vars={{ base: import.meta.env.BASE_URL }}>
    // boot do kernel: só na home, 1x por sessão, nunca em reduced-motion (antes da pintura).
    // "?boot" na URL força o boot (pra rever/demonstrar sem precisar de nova sessão).
    try {
      var here = location.pathname.replace(/\/+$/, '');
      var home = base.replace(/\/+$/, '');
      var force = false;
      try { force = new URLSearchParams(location.search).has('boot'); } catch (e2) { }
      if (here === home && !matchMedia('(prefers-reduced-motion: reduce)').matches && (force || sessionStorage.getItem('booted') !== '1')) {
        document.documentElement.classList.add('booting');
      }
    } catch (e) { }
  </script>
  <ClientRouter />
</head>

<body>
  <TopBar transition:persist />
  <slot />
  <Cursor transition:persist />
  <Terminal />
  <script>import '../scripts/portfolio.ts';</script>
</body>

</html>
