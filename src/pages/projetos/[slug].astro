---
import Base from '../../layouts/Base.astro';
import L from '../../components/L.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<Base title={`${project.title.en} · Henrique Targino`} description={project.lead.en}>
  <main class="detail">
    <div class="wrap">
      <a class="back-link" href={`${base}#proj-${project.slug}`}><L en="← back to projects" pt="← voltar pros projetos" /></a>
      <L as="p" class="cell-label" en={project.kind.en} pt={project.kind.pt} />
      <L as="h1" class="detail-title" en={project.title.en} pt={project.title.pt} />
      <L as="p" class="detail-lead" html en={project.lead.en} pt={project.lead.pt} />

      <div class="detail-cover">
        {project.coverIsVideo ? (
          <video src={`${base}${project.cover}`} autoplay loop muted controls playsinline data-autopause transition:name={`cover-${project.slug}`}></video>
        ) : (
          <img src={`${base}${project.cover}`} alt={project.title.en} transition:name={`cover-${project.slug}`} />
        )}
      </div>

      <div class="detail-meta">
        {(Array.isArray(project.metric) ? project.metric : [project.metric]).map((m) => (
          <div class="metric"><b>{m.value}</b><span><L en={m.label.en} pt={m.label.pt} /></span></div>
        ))}
        <div class="tags">{project.tags.map((t) => <span>{t}</span>)}</div>
      </div>

      <article class="detail-body">
        {project.sections.map((s) => (
          <section class="detail-section">
            <L as="h3" en={s.h3.en} pt={s.h3.pt} />
            {s.body.map((p) => <L as="p" html en={p.en} pt={p.pt} />)}
            {s.media && s.media.map((m) => (
              <figure class="detail-figure">
                {m.src.endsWith('.mp4') ? (
                  m.heavy ? (
                    <video src={`${base}${m.src}`} controls preload="metadata" playsinline></video>
                  ) : (
                    <video src={`${base}${m.src}`} autoplay loop muted controls playsinline data-autopause></video>
                  )
                ) : (
                  <img src={`${base}${m.src}`} alt={m.cap.en} loading="lazy" />
                )}
                <figcaption><L en={m.cap.en} pt={m.cap.pt} /></figcaption>
              </figure>
            ))}
          </section>
        ))}
      </article>

      {project.links && project.links.length > 0 && (
        <div class="detail-links">
          {project.links.map((l) => (
            <a href={l.href} target={l.href.startsWith('http') ? '_blank' : null} rel="noopener"><L en={l.label.en} pt={l.label.pt} /> →</a>
          ))}
        </div>
      )}

      <a class="back-link bottom" href={`${base}#proj-${project.slug}`}><L en="← back to projects" pt="← voltar pros projetos" /></a>
    </div>
  </main>
</Base>
