---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Instrumentos from '../components/Instrumentos.astro';
import FeatureProject from '../components/FeatureProject.astro';
import OtherProjects from '../components/OtherProjects.astro';
import Articles from '../components/Articles.astro';
import Certificates from '../components/Certificates.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;
---

<Base>
  <main>
    <Hero />
    <About />
    <Instrumentos />

    <FeatureProject
      cell="In [03]:"
      kind="visão computacional"
      title="Detector de Sinal de Socorro"
      lead="Um sistema que reconhece o gesto universal de pedido de ajuda em tempo real — só com webcam e CPU — e dispara um alerta silencioso via webhook."
      img="images/cv.jpeg"
      imgAlt="Frame da webcam detectando o gesto de socorro com 21 landmarks"
      figPhotoCap="<b>fig.02</b> · a câmera vê"
      rep="hand"
      figRepCap="<b>fig.03</b> · o modelo extrai 21 landmarks"
      body={[
        { h4: '// como funciona', text: 'O MediaPipe extrai 21 pontos da mão. Em vez de treinar um modelo pesado, o sistema usa geometria pura — a distância euclidiana entre os dedos — dentro de uma máquina de estados (ARMAR → DISPARAR → ALERTA) pra não confundir um aceno com um pedido de socorro.' },
        { h4: '// o impacto', text: 'A repercussão do projeto rendeu um convite pra ministrar uma masterclass de visão computacional na TripleTen. Quando o gesto é confirmado, um POST assíncrono dispara o alerta — em uma thread separada, sem travar o vídeo.' },
      ]}
      tags={['OpenCV', 'MediaPipe', 'NumPy', 'FSM', 'Python']}
      metricValue="21"
      metricLabel="landmarks · CPU · tempo real"
      href={`${base}projetos/detector-sos`}
    />

    <FeatureProject
      alt={true}
      cell="In [04]:"
      kind="redes neurais · reinforcement learning"
      title="AI Soccer"
      lead="Agentes que aprendem a jogar futebol do zero — sem nenhuma regra escrita à mão — em pura tentativa e erro, ao longo de 50 milhões de steps de treino."
      img="images/ai_soccer_nn.mp4"
      imgAlt="Visualização da rede neural do AI Soccer em ação"
      figPhotoCap="<b>fig.04</b> · a rede neural em ação"
      rep="nn"
      figRepCap="<b>fig.05</b> · a arquitetura, à mão"
      body={[
        { h4: '// a ideia', text: 'Nada de comportamento programado: os agentes começam sabendo nada e aprendem por reforço, jogando milhões de partidas contra si mesmos (self-play) até desenvolverem estratégia.' },
        { h4: '// por baixo dos panos', text: 'A política é uma rede neural treinada com um <strong>PPO próprio</strong> — escrito do zero, estilo CleanRL, sem bibliotecas de RL prontas — em PyTorch. Ela lê o estado do jogo e decide a ação, milhões de vezes, só na CPU.' },
      ]}
      tags={['PyTorch', 'PPO', 'Gymnasium', 'self-play', 'CPU-only']}
      metricValue="50M"
      metricLabel="steps de treino"
      href={`${base}projetos/ai-soccer`}
    />

    <OtherProjects />
    <Articles />
    <Certificates />
    <Footer />
  </main>
</Base>
