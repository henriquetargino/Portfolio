---
import Base from '../layouts/Base.astro';
import L from '../components/L.astro';
import { certificates } from '../data/certificates';
const base = import.meta.env.BASE_URL;
---

<Base title="Certificates · Henrique Targino" description="Certificates earned by Henrique Targino.">
  <main class="detail">
    <div class="wrap">
      <a class="back-link" href={`${base}#certificados`}><L en="← back to certificates" pt="← voltar pros certificados" /></a>
      <L as="p" class="cell-label out" en="// credentials" pt="// credenciais" />
      <L as="h1" class="detail-title" en="Certificates" pt="Certificados" />
      <L as="p" class="detail-lead" en="Some of the certificates I earned along the way." pt="Alguns dos certificados que conquistei ao longo da jornada." />

      <div class="cert-grid" style="margin-top:1rem;">
        {certificates.map((c) => (
          <a
            class="cert-card"
            href={(c.doc || c.image) ? `${base}${c.doc || c.image}` : undefined}
            target={(c.doc || c.image) ? '_blank' : undefined}
            rel="noopener"
          >
            <div class="cert-inst">
              <img src={`${base}${c.logo}`} alt={c.institution} />
              <span>{c.institution}</span>
            </div>
            <L as="h4" en={c.titleEn ?? c.title} pt={c.title} />
            <L as="p" class="cert-date" en={c.dateEn ?? c.date} pt={c.date} />
            {(c.doc || c.image) && <span class="cert-link"><L en="see certificate →" pt="ver certificado →" /></span>}
          </a>
        ))}
      </div>
    </div>
  </main>
</Base>
