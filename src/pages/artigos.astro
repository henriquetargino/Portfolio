---
import Base from '../layouts/Base.astro';
import L from '../components/L.astro';
import { articles } from '../data/articles';
const base = import.meta.env.BASE_URL;
---

<Base title="Articles · Henrique Targino" description="Articles written by Henrique Targino.">
  <main class="detail">
    <div class="wrap">
      <a class="back-link" href={`${base}#artigos`}><L en="← back to articles" pt="← voltar pros artigos" /></a>
      <L as="p" class="cell-label out" en="// writing" pt="// escritos" />
      <L as="h1" class="detail-title" en="Articles" pt="Artigos" />
      <L as="p" class="detail-lead" en="Writing where I open up the black box of my projects." pt="Textos onde eu abro a caixa-preta dos projetos." />

      <div class="article-list">
        {articles.map((a) => (
          <a class="article-card" href={a.href} target="_blank" rel="noopener">
            <div class="article-cover"><img src={`${base}${a.cover}`} alt={a.title} /></div>
            <div class="article-body">
              <L as="span" class="pub" en={a.pubEn ?? a.pub} pt={a.pub} />
              <h3>{a.title}</h3>
              <L as="p" class="article-excerpt" en={a.excerptEn ?? a.excerpt} pt={a.excerpt} />
              <span class="article-go"><L en="read on Medium →" pt="ler no Medium →" /></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Base>
